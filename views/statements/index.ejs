<%- include("../partials/header", { title: title }) %>

<h2>Tjenesteuttalelser</h2>
<p><a href="/uttalelser/ny">Skriv ny uttalelse</a></p>

<% if (statements.length === 0) { %>
  <p>Ingen uttalelser registrert ennå.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Elev</th>
        <th>Skrevet av</th>
        <th>Dato</th>
        <th>Tekst</th>
      </tr>
    </thead>
    <tbody>
      <% statements.forEach((statement) => { %>
        <tr>
          <td><%= statement.student ? statement.student.navn : "-" %></td>
          <td><%= statement.skrevetAv %></td>
          <td><%= statement.dato.toLocaleDateString("no-NO") %></td>
          <td><%= statement.tekst %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include("../partials/footer") %>
