<%- include("../partials/header", { title: title }) %>

<h2>Registrer bruker</h2>

<% if (error) { %>
  <p class="error"><%= error %></p>
<% } %>

<form action="/auth/register" method="POST">
  <label for="navn">Navn</label>
  <input id="navn" name="navn" type="text" required />

  <label for="epost">E-post</label>
  <input id="epost" name="epost" type="email" required />

  <label for="passord">Passord</label>
  <input id="passord" name="passord" type="password" required />

  <label for="rolle">Rolle</label>
  <select id="rolle" name="rolle" required>
    <option value="">Velg rolle</option>
    <option value="admin">admin</option>
    <option value="lærer">lærer</option>
    <option value="bedrift">bedrift</option>
    <option value="elev">elev</option>
  </select>

  <button type="submit">Registrer</button>
</form>

<%- include("../partials/footer") %>
