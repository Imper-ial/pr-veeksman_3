<!DOCTYPE html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Opplæringskontor</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <h1>Opplæringskontor</h1>
      <nav>
        <a href="/">Forside</a>
        <% if (currentUser) { %>
          <a href="/dashboard">Dashboard</a>
          <% if (currentUser.rolle === "admin") { %>
            <a href="/admin">Admin</a>
            <a href="/elever">Elever</a>
            <a href="/bedrifter">Bedrifter</a>
            <a href="/plasseringer">Plasseringer</a>
            <a href="/uttalelser">Uttalelser</a>
          <% } %>
          <% if (currentUser.rolle === "lærer") { %>
            <a href="/laerer/elever">Elevoversikt</a>
            <a href="/elever">Elever</a>
            <a href="/plasseringer">Plasseringer</a>
          <% } %>
          <% if (currentUser.rolle === "bedrift") { %>
            <a href="/bedrift">Bedrift-dashboard</a>
            <a href="/uttalelser/ny">Ny uttalelse</a>
          <% } %>
          <% if (currentUser.rolle === "elev") { %>
            <a href="/elev/min-side">Min side</a>
          <% } %>
          <a href="/auth/logout">Logg ut</a>
        <% } else { %>
          <a href="/auth/login">Logg inn</a>
          <a href="/auth/register">Registrer bruker</a>
        <% } %>
      </nav>
    </header>
    <main>
