<%- include("../partials/header", { title: title }) %>

<h2>Registrer ny elev</h2>

<% if (error) { %>
  <p class="error"><%= error %></p>
<% } %>

<form action="/elever" method="POST">
  <label for="navn">Navn</label>
  <input id="navn" name="navn" type="text" value="<%= formData.navn || '' %>" required />

  <label for="epost">E-post</label>
  <input id="epost" name="epost" type="email" value="<%= formData.epost || '' %>" required />

  <label for="telefon">Telefon (valgfritt)</label>
  <input id="telefon" name="telefon" type="text" value="<%= formData.telefon || '' %>" />

  <button type="submit">Lagre elev</button>
</form>

<%- include("../partials/footer") %>
