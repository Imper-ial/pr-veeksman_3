<%- include("../partials/header", { title: title }) %>

<h2>Admin-dashboard</h2>
<p>Hei <%= user.navn %>. Her ser du en enkel oversikt.</p>

<div class="cards">
  <div class="card">
    <h3>Antall elever</h3>
    <p><strong><%= studentCount %></strong></p>
  </div>
  <div class="card">
    <h3>Antall bedrifter</h3>
    <p><strong><%= companyCount %></strong></p>
  </div>
</div>

<h3>Varsler</h3>
<p>Slettet i dag: <%= cleanupResult.deletedPlacements %> plasseringer og <%= cleanupResult.deletedStatements %> uttalelser.</p>
<% if (finishedPlacements.length === 0) { %>
  <p>Ingen elever er ferdige i praksis enda.</p>
<% } else { %>
  <ul>
    <% finishedPlacements.forEach((placement) => { %>
      <li><%= placement.student?.navn || "Ukjent elev" %> er ferdig i praksis (sluttdato: <%= placement.sluttDato.toLocaleDateString("no-NO") %>).</li>
    <% }) %>
  </ul>
<% } %>
<% if (placementsReadyForDeletion.length > 0) { %>
  <h4>Plasseringer klare for sletting</h4>
  <ul>
    <% placementsReadyForDeletion.forEach((placement) => { %>
      <li><%= placement.student?.navn || "Ukjent elev" %> (sluttdato: <%= placement.sluttDato.toLocaleDateString("no-NO") %>).</li>
    <% }) %>
  </ul>
<% } %>

<p>Gå videre:</p>
<ul>
  <li><a href="/laerer/elever">Elevoversikt</a></li>
  <li><a href="/bedrifter">Bedrifter</a></li>
  <li><a href="/plasseringer">Plasseringer</a></li>
</ul>

<%- include("../partials/footer") %>
